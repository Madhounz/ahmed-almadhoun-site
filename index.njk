permalink: /index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ahmed Almadhoun — Transport Engineer & Photographer</title>
<meta name="description" content="Transport engineer and PhD researcher at Warsaw University of Technology. Freight systems, spatial accessibility, and photography.">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --black:#060606;--charcoal:#0f0f0f;--dim:#141414;--panel:#1a1a1a;
  --border:rgba(255,255,255,0.07);--gold:#c9a84c;--gold-dim:rgba(201,168,76,0.1);
  --white:#f0ede6;--muted:rgba(240,237,230,0.42);--faint:rgba(240,237,230,0.14);
  --serif:'Cormorant Garamond',Georgia,serif;--mono:'Space Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:var(--serif);font-weight:300;overflow-x:hidden;cursor:crosshair}
::selection{background:var(--gold-dim);color:var(--gold)}
#cur{position:fixed;width:6px;height:6px;border-radius:50%;background:var(--gold);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:screen}
#cur-r{position:fixed;width:30px;height:30px;border-radius:50%;border:1px solid rgba(201,168,76,0.35);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .22s,height .22s,border-color .22s}
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:24px 52px;display:flex;justify-content:space-between;align-items:center;background:linear-gradient(to bottom,rgba(6,6,6,0.95),transparent)}
.nav-logo{font-family:var(--mono);font-size:11px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);text-decoration:none}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .3s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-3px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.nav-links a:hover{color:var(--white)}
.nav-links a:hover::after{width:100%}
#hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 52px 80px;position:relative;overflow:hidden}
.hero-glow{position:absolute;inset:0;background:radial-gradient(ellipse 55% 65% at 65% 35%,rgba(201,168,76,0.06) 0%,transparent 60%)}
.hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.012) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.012) 1px,transparent 1px);background-size:80px 80px}
.hero-frame{position:absolute;top:44px;right:52px;bottom:44px;left:52px;border:1px solid rgba(201,168,76,0.09);pointer-events:none}
.hero-frame::before,.hero-frame::after{content:'';position:absolute;width:18px;height:18px;border-color:rgba(201,168,76,0.6);border-style:solid}
.hero-frame::before{top:-1px;left:-1px;border-width:1px 0 0 1px}
.hero-frame::after{bottom:-1px;right:-1px;border-width:0 1px 1px 0}
.hero-tag{font-family:var(--mono);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;opacity:0;animation:fadeUp 1s ease .3s forwards}
.hero-name{font-family:var(--serif);font-size:clamp(64px,9.5vw,130px);font-weight:300;line-height:.88;letter-spacing:-.02em;color:var(--white);opacity:0;animation:fadeUp 1.2s ease .5s forwards}
.hero-name em{font-style:italic;color:var(--gold)}
.hero-sub{margin-top:28px;max-width:500px;font-size:17px;line-height:1.85;color:var(--muted);opacity:0;animation:fadeUp 1s ease .8s forwards}
.hero-sub span{color:var(--white);font-style:italic}
.hero-pills{display:flex;gap:12px;margin-top:32px;opacity:0;animation:fadeUp 1s ease 1s forwards;flex-wrap:wrap}
.pill{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;padding:7px 16px;border:1px solid rgba(201,168,76,0.25);color:var(--gold);cursor:pointer;transition:background .3s,border-color .3s;text-decoration:none}
.pill:hover{background:var(--gold-dim);border-color:rgba(201,168,76,0.5)}
.hero-scroll{position:absolute;right:52px;bottom:80px;display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;animation:fadeIn 1s ease 1.5s forwards}
.hero-scroll span{font-family:var(--mono);font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);writing-mode:vertical-rl}
.scroll-line{width:1px;height:56px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollPulse 2s ease-in-out infinite}
section{padding:110px 52px;position:relative}
.s-label{font-family:var(--mono);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
.s-title{font-size:clamp(36px,4.5vw,66px);font-weight:300;line-height:1.05;letter-spacing:-.02em;color:var(--white);margin-bottom:56px}
.s-title em{font-style:italic;color:var(--gold)}
.divider{width:1px;height:72px;background:linear-gradient(to bottom,transparent,var(--gold-dim),transparent);margin:0 auto}
.reveal{opacity:0;transform:translateY(36px);transition:opacity .85s ease,transform .85s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
#about{background:var(--charcoal)}
.about-grid{display:grid;grid-template-columns:1.3fr .7fr;gap:72px;align-items:start}
.about-text p{font-size:18px;line-height:1.9;color:var(--muted);margin-bottom:18px}
.about-text p strong{color:var(--white);font-weight:400}
.about-stats{display:flex;flex-direction:column;gap:32px}
.stat{border-left:1px solid var(--gold);padding-left:22px}
.stat-num{font-size:48px;font-weight:300;color:var(--white);line-height:1;font-style:italic}
.stat-label{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-top:5px}
#gallery{background:var(--black);padding-bottom:0}
.gallery-intro{font-size:18px;line-height:1.85;color:var(--muted);max-width:520px;margin-bottom:72px}
.gallery-intro em{color:var(--white);font-style:italic}
.masonry-grid{columns:3;column-gap:4px}
.masonry-item{break-inside:avoid;margin-bottom:4px;position:relative;overflow:hidden;cursor:pointer}
.masonry-item img{width:100%;display:block;transition:transform .6s ease}
.masonry-item:hover img{transform:scale(1.04)}
.masonry-caption{position:absolute;bottom:0;left:0;right:0;padding:32px 16px 14px;background:linear-gradient(to top,rgba(6,6,6,.88),transparent);opacity:0;transform:translateY(6px);transition:opacity .4s,transform .4s}
.masonry-item:hover .masonry-caption{opacity:1;transform:translateY(0)}
.masonry-caption h4{font-size:15px;font-weight:300;color:var(--white);margin-bottom:2px}
.masonry-caption span{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.ph-inner{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:60px 20px;background:var(--dim)}
.ph-icon{width:36px;height:36px;border:1px solid rgba(201,168,76,0.2);display:flex;align-items:center;justify-content:center}
.ph-icon svg{width:16px;height:16px;stroke:var(--gold);fill:none;stroke-width:1.5;opacity:.5}
.ph-label{font-family:var(--mono);font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:var(--faint)}
#lb{position:fixed;inset:0;background:rgba(6,6,6,.97);z-index:500;display:none;align-items:center;justify-content:center;cursor:zoom-out;flex-direction:column;gap:16px}
#lb.open{display:flex}
#lb img{max-width:90vw;max-height:85vh;object-fit:contain}
#lb-meta{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
#lb-close{position:absolute;top:28px;right:36px;font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);cursor:pointer;transition:color .2s;background:none;border:none}
#lb-close:hover{color:var(--gold)}
.gallery-cta{padding:48px 52px;display:flex;align-items:center;gap:24px}
.gallery-cta a{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:1px solid rgba(201,168,76,.3);padding-bottom:3px;transition:border-color .3s}
.gallery-cta a:hover{border-color:var(--gold)}
.gallery-cta span{font-family:var(--mono);font-size:10px;color:var(--faint)}
.no-content{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--faint);padding:40px 0}
#research{background:var(--dim)}
.research-list{display:flex;flex-direction:column}
.r-item{display:grid;grid-template-columns:52px 1fr;gap:28px;padding:32px 0;border-bottom:1px solid var(--border);position:relative}
.r-item:first-child{border-top:1px solid var(--border)}
.r-item::before{content:'';position:absolute;left:-52px;right:-52px;top:0;bottom:0;background:var(--gold-dim);opacity:0;transition:opacity .3s;pointer-events:none}
.r-item:hover::before{opacity:1}
.r-num{font-family:var(--mono);font-size:11px;color:var(--gold);letter-spacing:.1em;padding-top:4px;position:relative;z-index:1}
.r-body{position:relative;z-index:1}
.r-body h3{font-size:20px;font-weight:300;color:var(--white);margin-bottom:7px;letter-spacing:-.01em}
.r-body p{font-size:12px;color:var(--muted);font-family:var(--mono);margin-bottom:12px}
.r-actions{display:flex;gap:10px;flex-wrap:wrap}
.r-btn{font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:5px 14px;border:1px solid rgba(201,168,76,0.25);color:var(--gold);text-decoration:none;transition:background .25s;cursor:pointer;background:none}
.r-btn:hover,.r-btn.filled{background:var(--gold-dim);border-color:rgba(201,168,76,.5)}
.r-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.r-abstract{display:none;margin-top:14px;font-size:15px;line-height:1.8;color:var(--muted);border-left:1px solid rgba(201,168,76,0.2);padding-left:16px}
.r-item.open .r-abstract{display:block}
.r-body h3{cursor:pointer}
.r-body h3:hover{color:var(--gold)}
.tag{font-family:var(--mono);font-size:9px;letter-spacing:.13em;text-transform:uppercase;padding:4px 11px;border:1px solid rgba(201,168,76,.2);color:rgba(201,168,76,.65);border-radius:1px}
#pdf-overlay{position:fixed;inset:0;background:rgba(6,6,6,.97);z-index:500;display:none;flex-direction:column}
#pdf-overlay.open{display:flex}
.pdf-header{display:flex;justify-content:space-between;align-items:center;padding:20px 36px;border-bottom:1px solid var(--border)}
.pdf-header span{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
.pdf-close{font-family:var(--mono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);cursor:pointer;background:none;border:none}
#thoughts{background:var(--charcoal)}
.thoughts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2px}
.thought-card{background:var(--dim);padding:36px 32px;cursor:pointer;position:relative;overflow:hidden;transition:background .3s}
.thought-card::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform .4s;transform-origin:left}
.thought-card:hover{background:var(--panel)}
.thought-card:hover::before{transform:scaleX(1)}
.t-date{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.t-title{font-size:22px;font-weight:300;color:var(--white);line-height:1.25;margin-bottom:12px;letter-spacing:-.01em}
.t-excerpt{font-size:14px;line-height:1.75;color:var(--muted)}
#post-overlay{position:fixed;inset:0;z-index:600;background:#060606;display:none;flex-direction:column;overflow-y:auto;cursor:default}
#post-overlay.open{display:flex}
.post-curtain{position:fixed;top:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .8s ease;z-index:601}
#post-overlay.open .post-curtain{transform:scaleX(1)}
.post-inner{max-width:680px;margin:0 auto;padding:120px 40px 80px;opacity:0;transform:translateY(24px);transition:opacity .7s ease .4s,transform .7s ease .4s}
#post-overlay.open .post-inner{opacity:1;transform:translateY(0)}
.post-meta{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,168,76,0.6);margin-bottom:40px;display:flex;gap:24px}
.post-title{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(36px,6vw,72px);font-weight:300;line-height:1.05;letter-spacing:-.02em;color:#f0ede6;margin-bottom:48px}
.post-title em{font-style:italic;color:#c9a84c}
.post-divider{width:48px;height:1px;background:#c9a84c;margin-bottom:48px;opacity:.5}
.post-body{font-family:'Cormorant Garamond',Georgia,serif;font-size:20px;font-weight:300;line-height:1.9;color:rgba(240,237,230,0.7)}
.post-body p{margin-bottom:28px}
.post-close{position:fixed;top:32px;right:40px;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.25em;text-transform:uppercase;color:rgba(240,237,230,0.35);background:none;border:none;cursor:pointer;transition:color .2s;z-index:602}
.post-close:hover{color:#c9a84c}
.thought-card .t-title{cursor:pointer;transition:color .3s}
.thought-card:hover .t-title{color:#c9a84c}
.t-cat{display:inline-block;margin-top:20px;font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:4px 12px;border:1px solid rgba(201,168,76,.2);color:rgba(201,168,76,.6)}
#contact{background:var(--black);text-align:center}
.contact-inner{max-width:600px;margin:0 auto}
.contact-email{display:inline-block;font-size:clamp(16px,2.8vw,32px);font-weight:300;font-style:italic;color:var(--white);text-decoration:none;border-bottom:1px solid var(--gold);padding-bottom:3px;margin:28px 0 44px;transition:color .3s}
.contact-email:hover{color:var(--gold)}
.social-row{display:flex;justify-content:center;gap:32px;list-style:none;flex-wrap:wrap}
.social-row a{font-family:var(--mono);font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .3s}
.social-row a:hover{color:var(--gold)}
footer{padding:28px 52px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
footer span{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--faint)}
.admin-hint{position:fixed;bottom:24px;right:24px;z-index:100;opacity:.04;transition:opacity .3s}
.admin-hint:hover{opacity:.6}
.admin-hint a{font-family:var(--mono);font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:var(--faint);text-decoration:none;padding:7px 12px;border:1px solid rgba(255,255,255,0.06)}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scrollPulse{0%,100%{transform:scaleY(1);opacity:1}50%{transform:scaleY(.55);opacity:.35}}
@media(max-width:768px){
  nav{padding:18px 20px}.nav-links{display:none}
  section{padding:72px 20px}#hero{padding:0 20px 56px}
  .hero-frame{display:none}.about-grid{grid-template-columns:1fr;gap:40px}
  .masonry-grid{columns:2}
  .thoughts-grid{grid-template-columns:1fr}
  footer{flex-direction:column;gap:12px;text-align:center}
  .gallery-cta{padding:32px 20px}
}
</style>
</head>
<body>

<div id="cur"></div>
<div id="cur-r"></div>

<div id="lb">
  <button id="lb-close">Close ✕</button>
  <img id="lb-img" src="" alt="">
  <div id="lb-meta"></div>
</div>

<div id="pdf-overlay">
  <div class="pdf-header">
    <span id="pdf-title">Paper</span>
    <button class="pdf-close" onclick="closePdf()">Close ✕</button>
  </div>
  <iframe style="flex:1;border:none" id="pdf-frame" src=""></iframe>
</div>

<div id="post-overlay">
  <div class="post-curtain"></div>
  <button class="post-close" onclick="closePost()">Close ✕</button>
  <div class="post-inner">
    <div class="post-meta">
      <span id="post-date"></span>
      <span id="post-cat"></span>
    </div>
    <h1 class="post-title" id="post-title"></h1>
    <div class="post-divider"></div>
    <div class="post-body" id="post-body"></div>
  </div>
</div>

<nav>
  <a href="#hero" class="nav-logo">A.A.</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#research">Research</a></li>
    <li><a href="#thoughts">Thoughts</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-grid-bg"></div>
  <div class="hero-frame"></div>
  <div class="hero-tag">Transport Engineer · PhD Researcher · Warsaw University of Technology</div>
  <h1 class="hero-name">Ahmed<br><em>Almadhoun</em></h1>
  <p class="hero-sub">I study how broken infrastructure quietly <span>disconnects businesses and entire regions</span> — using real data, simulation, and spatial analysis to make freight systems work for everyone. When I'm not in the lab, I'm chasing the kind of light that makes cities look like they're holding their breath.</p>
  <div class="hero-pills">
    <a href="#gallery" class="pill">Photography</a>
    <a href="#research" class="pill">Research</a>
    <a href="#thoughts" class="pill">Thoughts</a>
    <a href="#contact" class="pill">Contact</a>
  </div>
  <div class="hero-scroll"><span>Scroll</span><div class="scroll-line"></div></div>
</section>

<section id="about">
  <div class="reveal">
    <div class="s-label">/ 01 — Identity</div>
    <h2 class="s-title">Two fields.<br><em>One practice.</em></h2>
  </div>
  <div class="about-grid reveal">
    <div class="about-text">
      <p>I am a <strong>transport engineer and PhD researcher at the Faculty of Transport, Warsaw University of Technology</strong>, supervised by Prof. Kostrzewski. I also serve as a teaching assistant at the same faculty — helping shape the next generation of transport engineers.</p>
      <p>My research asks a simple but underexplored question: how does poor infrastructure quietly cut off entire businesses and regions from economic opportunity? I build spatial frameworks — including the <strong>Freight Accessibility Index (FAI)</strong> — using real corridor data, simulation, and spatial analysis to make that invisible damage visible and measurable.</p>
      <p>Outside the lab, I photograph places the way I study them — <strong>slowly, deliberately</strong>. Lately I've been shooting on film-style settings, chasing the grain and stillness of old Kodak frames. Cities look different when you slow down enough to actually see them.</p>
    </div>
    <div class="about-stats">
      <div class="stat"><div class="stat-num">2022</div><div class="stat-label">Joined WUT — MSc then PhD</div></div>
      <div class="stat"><div class="stat-num">3</div><div class="stat-label">Languages — AR · EN · PL</div></div>
      <div class="stat"><div class="stat-num">WUT</div><div class="stat-label">Faculty of Transport · Warsaw</div></div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section id="gallery">
  <div class="reveal">
    <div class="s-label">/ 02 — Photography</div>
    <h2 class="s-title">Through the<br><em>viewfinder.</em></h2>
  </div>
  <p class="gallery-intro reveal">Each frame is a question asked with light. <em>Warsaw's geometry, foreign streets, quiet moments.</em> The same eye that reads a freight corridor reads a composition.</p>

  <div class="masonry-grid reveal" id="masonry">
    {% if photos and photos.length %}
      {% for photo in photos %}
      <div class="masonry-item" data-title="{{ photo.title }}" data-loc="{{ photo.location }}">
        {% if photo.image %}
          <img src="{{ photo.image }}" alt="{{ photo.title }}">
        {% else %}
          <div class="ph-inner">
            <div class="ph-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="1"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
            <span class="ph-label">{{ photo.title }}</span>
          </div>
        {% endif %}
        <div class="masonry-caption"><h4>{{ photo.title }}</h4><span>{{ photo.location }}</span></div>
      </div>
      {% endfor %}
    {% else %}
      <div class="no-content">No photos yet — add some via /admin</div>
    {% endif %}
  </div>

  <div class="gallery-cta">
    <a href="https://www.instagram.com/fotozitake/" target="_blank">Full feed on @fotozitake</a>
    <span>·</span>
    <a href="https://www.instagram.com/fotozitake/" target="_blank">Instagram →</a>
  </div>
</section>

<div class="divider"></div>

<section id="research">
  <div class="reveal">
    <div class="s-label">/ 03 — Research</div>
    <h2 class="s-title">The work<br><em>on paper.</em></h2>
  </div>
  <div class="research-list reveal">
    {% if research and research.length %}
      {% for paper in research %}
      <div class="r-item">
        <span class="r-num">{{ loop.index }}</span>
        <div class="r-body">
          <h3>{{ paper.title }}</h3>
          <p>{{ paper.venue }}</p>
          <div class="r-actions">
            {% if paper.pdf %}<button class="r-btn filled" onclick="openPdf('{{ paper.pdf }}','{{ paper.title }}')">Read Paper</button>{% endif %}
            {% if paper.doi %}<a class="r-btn" href="{{ paper.doi }}" target="_blank">DOI Link</a>{% endif %}
            <a class="r-btn" href="https://scholar.google.com/citations?user=lB2_-wEAAAAJ&hl=en" target="_blank">Google Scholar</a>
          </div>
{% if paper.abstract %}<div class="r-abstract">{{ paper.abstract }}</div>{% endif %}
          {% if paper.tags %}
          <div class="r-tags">
            {% for tag in paper.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    {% else %}
      <div class="r-item">
        <span class="r-num">001</span>
        <div class="r-body">
          <h3>Freight Accessibility Index & Freight Accessibility Potential in Warsaw Corridors</h3>
          <p>Warsaw University of Technology · 2025 · Target: Transportation Research Part A (Q1, IF 7.8)</p>
          <div class="r-actions">
            <a class="r-btn" href="https://scholar.google.com/citations?user=lB2_-wEAAAAJ&hl=en" target="_blank">Google Scholar</a>
            <a class="r-btn" href="https://repo.pw.edu.pl/info/author/WUT263df5ff3c6b49e38ab5c8e6201acbb9" target="_blank">WUT Repository</a>
          </div>
          <div class="r-tags"><span class="tag">FAI / FAP</span><span class="tag">Spatial Analysis</span><span class="tag">Warsaw</span><span class="tag">Q1</span></div>
        </div>
      </div>
      <div class="r-item">
        <span class="r-num">002</span>
        <div class="r-body">
          <h3>Transport Poverty in Freight Transportation</h3>
          <p>PhD Thesis · Faculty of Transport, WUT · Ongoing</p>
          <div class="r-actions">
            <a class="r-btn" href="https://repo.pw.edu.pl/info/author/WUT263df5ff3c6b49e38ab5c8e6201acbb9" target="_blank">WUT Repository</a>
          </div>
          <div class="r-tags"><span class="tag">PhD</span><span class="tag">Freight</span><span class="tag">Transport Poverty</span></div>
        </div>
      </div>
      <div class="r-item">
        <span class="r-num">003</span>
