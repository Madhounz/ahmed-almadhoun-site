<section id="research" class="section">
  <div class="wrap">
    <div class="reveal">
      <div class="section-label">Research</div>
      <h2 class="section-title">Research and publications</h2>
    </div>
    <div class="research-list reveal">
      {% if research and research.length %}
        {% for paper in research %}
        <div class="r-card">
          <div class="r-num">{% if loop.index < 10 %}0{{ loop.index }}{% else %}{{ loop.index }}{% endif %}</div>
          <h3 class="r-title" onclick="toggleResearch(this)" onkeydown="if(event.key==='Enter'||event.key===' '){toggleResearch(this);event.preventDefault()}" tabindex="0" role="button" aria-expanded="false">{{ paper.title }}<span class="r-toggle">+</span></h3>
          <p class="r-abstract">{{ paper.abstract }}</p>
          {% if paper.tags %}
          <div class="r-tags">
            {% for tag in paper.tags %}<span class="r-tag">{{ tag }}</span>{% endfor %}
          </div>
          {% endif %}
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:4px">
            {% if paper.pdf %}<button onclick="window.open('{{ paper.pdf }}','_blank')" style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit" class="r-link">Read Paper <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10L10 2M10 2H5M10 2v5"/></svg></button>{% endif %}
            {% if paper.doi %}<a href="{{ paper.doi }}" target="_blank" class="r-link">DOI Link <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10L10 2M10 2H5M10 2v5"/></svg></a>{% endif %}
            <a href="https://scholar.google.com/citations?user=lB2_-wEAAAAJ&hl=en" target="_blank" class="r-link">Google Scholar <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10L10 2M10 2H5M10 2v5"/></svg></a>
          </div>
          <div class="r-meta">{{ paper.venue }}</div>
          {% if loop.index === 2 %}
          <div style="margin-top:20px">
            <button onclick="toggleMap()" id="map-toggle-btn" class="btn btn-outline" style="font-size:13px">
              View Warsaw Corridor Data <span id="map-btn-icon">↓</span>
            </button>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      {% else %}
        <div class="r-card">
          <div class="r-num">01</div>
          <h3 class="r-title" onclick="toggleResearch(this)" onkeydown="if(event.key==='Enter'||event.key===' '){toggleResearch(this);event.preventDefault()}" tabindex="0" role="button" aria-expanded="false">Freight Accessibility in Warsaw Corridors<span class="r-toggle">+</span></h3>
          <p class="r-abstract">A spatial framework measuring how well urban logistics corridors serve the areas they connect. Applied to Warsaw's freight network to identify hidden penalties in infrastructure quality and corridor performance.</p>
          <div class="r-tags"><span class="r-tag">Spatial Analysis</span><span class="r-tag">Warsaw</span><span class="r-tag">Q1 Target</span></div>
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:4px">
            <a href="https://scholar.google.com/citations?user=lB2_-wEAAAAJ&hl=en" target="_blank" class="r-link">Google Scholar <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10L10 2M10 2H5M10 2v5"/></svg></a>
          </div>
          <div class="r-meta">WUT · 2025 · Transportation Research Part A</div>
        </div>
      {% endif %}
    </div>
