  <a href="/#photography" class="nav-back">← Back</a>
</nav>

<div class="page-wrap">
  <section class="hero reveal">
    <div class="hero-grid">
      <div>
        <div class="hero-label">Photography Archive</div>
        <h1 class="hero-title">Through<br>the viewfinder.</h1>
        <p class="hero-sub">Stillness, structure, and quiet geometry. Move across the map, enter a city, and let the atmosphere open one frame at a time.</p>
      </div>
      <div class="hero-side">
        <div class="hero-card">
          <div class="hero-card-top">
            <div>
              <div class="hero-card-label">Current Selection</div>
              <div class="hero-card-value" id="hero-city-short">Budapest</div>
            </div>
            <div class="hero-card-sub" id="hero-city-copy">Architectural stillness, layered light, and symmetry held just before motion.</div>
          </div>
          <div class="hero-meter"></div>
          <div class="hero-stats">
            <div class="hero-stat">
              <div class="hero-stat-num" id="hero-total-photos">0</div>
              <div class="hero-stat-label">Photographs</div>
            </div>
            <div class="hero-stat">
              <div class="hero-stat-num" id="hero-total-cities">0</div>
              <div class="hero-stat-label">Cities</div>
            </div>
            <div class="hero-stat">
              <div class="hero-stat-num" id="hero-featured-count">0</div>
              <div class="hero-stat-label">In View</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="stage-shell reveal">
    <div class="map-panel">
      <div class="map-top">
        <div>
          <div class="map-title">A map of memory and light.</div>
        </div>
        <div class="map-copy">Select a city pin or use the selector below. Each location becomes a different visual mood, not just a different folder.</div>
      </div>
