      <path d="M 1060,155 L 1090,165 L 1115,178 L 1135,195 L 1150,215 L 1158,238 L 1155,260 L 1145,278 L 1130,292 L 1110,300 L 1085,305 L 1060,298 L 1040,282 L 1028,265 L 1025,245 L 1030,225 L 1040,208 L 1048,188 L 1052,168 Z" fill="rgba(196,138,66,0.04)" stroke="rgba(196,138,66,0.15)" stroke-width="0.8"/>
      <text x="680" y="380" font-family="Inter,sans-serif" font-size="9" fill="rgba(196,138,66,0.2)" text-anchor="middle" letter-spacing="3">MEDITERRANEAN</text>
