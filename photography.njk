      <div class="pin-tooltip">Kraków</div>
    </div>

    <div class="city-pin" id="pin-budapest" data-city="budapest" style="left:56.5%;top:38%">
      <div class="pin-pulse"></div><div class="pin-pulse pin-pulse2"></div>
