<div id="lb">
  <button id="lb-close">Close</button>
  <img id="lb-img" src="" alt="">
</div>

<button id="theme-btn" onclick="
  document.body.classList.toggle('dark-mode');
  const dark=document.body.classList.contains('dark-mode');
  this.textContent=dark?'Light':'Dark';
  localStorage.setItem('theme',dark?'dark':'light');
">Dark</button>

<script>
(function(){
  const saved=localStorage.getItem('theme');
  if(saved==='dark'){
    document.body.classList.add('dark-mode');
    const btn=document.getElementById('theme-btn');
    if(btn)btn.textContent='Light';
  }
})();
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')});
},{threshold:.07});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

const lb=document.getElementById('lb');
const lbImg=document.getElementById('lb-img');

function openLb(src){
  lbImg.src=src;
  lb.style.display='flex';
  requestAnimationFrame(()=>requestAnimationFrame(()=>lb.classList.add('visible')));
}
function closeLb(){
  lb.classList.remove('visible');
  setTimeout(()=>{lb.style.display='none';lbImg.src=''},300);
}

document.querySelectorAll('.photo-cell').forEach(cell=>{
  cell.addEventListener('click',()=>{
    const img=cell.querySelector('img');
    if(img&&img.src) openLb(img.src);
  });
});
lb.addEventListener('click',e=>{if(e.target===lb)closeLb()});
document.getElementById('lb-close').addEventListener('click',closeLb);

document.querySelectorAll('.t-card').forEach(card=>{
  card.addEventListener('click',()=>{
    document.getElementById('post-heading').textContent=card.dataset.title||'';
    document.getElementById('post-date').textContent=card.dataset.date||'';
    document.getElementById('post-cat').textContent=card.dataset.cat||'';
    const src=card.querySelector('.t-body-source');
    const body=src?src.innerHTML.trim():'';
    const exc=card.dataset.excerpt||'';
    document.getElementById('post-body').innerHTML=body||'<p>'+exc+'</p>';
    const po=document.getElementById('post-overlay');
    po.style.display='flex';
    requestAnimationFrame(()=>requestAnimationFrame(()=>po.classList.add('visible')));
    document.body.style.overflow='hidden';
    po.onclick=e=>{if(e.target===po)closePost();};
  });
});

function closePost(){
  const po=document.getElementById('post-overlay');
  po.classList.remove('visible');
  setTimeout(()=>{po.style.display='none';document.body.style.overflow='';},350);
}
function toggleResearch(el){
  const card=el.closest('.r-card');
  const isOpen=card.classList.toggle('open');
  el.setAttribute('aria-expanded',isOpen?'true':'false');
}
window.toggleResearch=toggleResearch;
window.closePost=closePost;
const cf=document.getElementById('contact-form');
if(cf){cf.addEventListener('submit',async e=>{
  e.preventDefault();
  const data=new FormData(cf);
  await fetch('/',{method:'POST',body:data});
  cf.querySelectorAll('.cf-input,.cf-textarea').forEach(el=>el.value='');
  const s=document.getElementById('cf-success');
  s.style.display='block';
  setTimeout(()=>s.style.display='none',5000);
});}


document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    if(document.getElementById('post-overlay').classList.contains('visible')) closePost();
    else closeLb();
  }
});
// === FEATURE 1: Typed hero ===
(function(){
  const phrases=['Freight systems & accessibility','Transport poverty research','Infrastructure equity','Spatial analysis','The invisible things.'];
  let i=0,j=0,deleting=false,pause=false;
  const el=document.getElementById('typed-text');
  if(!el)return;
  function tick(){
    const word=phrases[i];
    if(pause){pause=false;setTimeout(tick,1800);return;}
    if(!deleting){
      el.textContent=word.slice(0,++j);
      if(j===word.length){deleting=true;pause=true;setTimeout(tick,60);return;}
      setTimeout(tick,65);
    } else {
      el.textContent=word.slice(0,--j);
      if(j===0){deleting=false;i=(i+1)%phrases.length;setTimeout(tick,400);return;}
      setTimeout(tick,35);
    }
  }
  setTimeout(tick,1200);
})();

// === FEATURE 2: Timeline scroll reveal ===
(function(){
  const items=document.querySelectorAll('.tl-item');
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting)e.target.classList.add('tl-visible');
    });
  },{threshold:.15});
  items.forEach(el=>obs.observe(el));
})();

