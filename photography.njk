            <line x1="600" y1="0" x2="600" y2="540" stroke="#c48a42" stroke-width="0.45"/>
            <line x1="900" y1="0" x2="900" y2="540" stroke="#c48a42" stroke-width="0.45"/>
          </g>
          <path d="M 180,70 L 222,52 L 266,56 L 315,46 L 352,52 L 395,42 L 430,50 L 470,40 L 512,45 L 544,37 L 574,43 L 604,38 L 642,44 L 678,55 L 708,49 L 730,58 L 750,54 L 772,61 L 792,56 L 816,66 L 835,60 L 860,70 L 883,64 L 903,74 L 924,70 L 944,79 L 964,75 L 986,84 L 1005,80 L 1024,91 L 1034,103 L 1032,122 L 1023,136 L 1009,149 L 987,157 L 968,163 L 953,177 L 944,190 L 933,205 L 922,219 L 903,227 L 882,235 L 860,243 L 842,248 L 823,255 L 802,264 L 783,270 L 764,276 L 744,284 L 724,291 L 703,296 L 684,302 L 664,308 L 644,316 L 621,321 L 601,325 L 579,328 L 560,321 L 539,314 L 518,321 L 498,316 L 479,323 L 458,318 L 438,325 L 418,320 L 399,327 L 380,321 L 360,327 L 339,320 L 320,324 L 299,317 L 280,321 L 260,315 L 242,321 L 220,311 L 201,314 L 186,306 L 177,292 L 171,278 L 166,263 L 163,246 L 160,231 L 157,216 L 155,200 L 152,184 L 149,167 L 147,150 L 144,133 L 142,116 L 141,99 L 144,83 L 156,71 L 170,63 Z" fill="rgba(196,138,66,.055)" stroke="rgba(196,138,66,.18)" stroke-width="1.1" stroke-linejoin="round"/>
          <path d="M 420,50 L 432,22 L 451,14 L 470,20 L 482,32 L 472,40 Z" fill="rgba(196,138,66,.04)" stroke="rgba(196,138,66,.12)" stroke-width=".8"/>
          <path d="M 187,307 L 175,322 L 165,339 L 156,357 L 159,372 L 169,383 L 183,390 L 201,384 L 217,370 L 223,354 L 219,338 L 210,323 L 200,313 Z" fill="rgba(196,138,66,.035)" stroke="rgba(196,138,66,.1)" stroke-width=".8"/>
          <path d="M 562,321 L 556,338 L 549,352 L 543,368 L 540,382 L 544,397 L 552,404 L 562,400 L 569,386 L 571,369 L 570,354 L 567,340 Z" fill="rgba(196,138,66,.03)" stroke="rgba(196,138,66,.1)" stroke-width=".8"/>
          <path d="M 699,296 L 710,313 L 718,328 L 713,343 L 703,354 L 691,359 L 682,356 L 676,343 L 679,327 L 686,311 L 692,301 Z" fill="rgba(196,138,66,.03)" stroke="rgba(196,138,66,.1)" stroke-width=".8"/>
          <path d="M 969,84 L 1020,92 L 1061,98 L 1090,108 L 1110,120 L 1115,135 L 1106,146 L 1088,152 L 1060,157 L 1037,153 L 1010,149 L 990,157 L 970,149 L 956,136 L 951,121 L 956,107 Z" fill="rgba(196,138,66,.045)" stroke="rgba(196,138,66,.16)" stroke-width=".8"/>
          <path d="M 1060,157 L 1090,167 L 1116,180 L 1137,197 L 1150,216 L 1159,238 L 1156,260 L 1146,279 L 1129,293 L 1111,301 L 1087,306 L 1062,299 L 1041,284 L 1029,267 L 1024,245 L 1030,226 L 1040,208 L 1048,190 L 1053,170 Z" fill="rgba(196,138,66,.03)" stroke="rgba(196,138,66,.1)" stroke-width=".8"/>
          <text x="690" y="392" font-family="Inter,sans-serif" font-size="9" fill="rgba(196,138,66,.22)" text-anchor="middle" letter-spacing="3">MEDITERRANEAN</text>
        </svg>

        <svg class="route-svg" viewBox="0 0 1200 540" preserveAspectRatio="none" aria-hidden="true">
          <path class="route-path" id="route-west" d="M642 172 Q 610 160 582 206 Q 560 246 560 292"/>
          <path class="route-path" id="route-east" d="M642 172 Q 742 150 858 206"/>
          <path class="route-path" id="route-far-east" d="M858 206 Q 920 182 960 138"/>
          <circle class="route-dot" cx="642" cy="172" r="3"/>
          <circle class="route-dot" cx="560" cy="292" r="3"/>
          <circle class="route-dot" cx="858" cy="206" r="3"/>
          <circle class="route-dot" cx="960" cy="138" r="3"/>
        </svg>

        <div class="map-glow" id="map-glow"></div>

        <div class="city-pin active" id="pin-budapest" data-city="budapest" style="left:53.5%;top:38%">
          <div class="pin-ray"></div><div class="pin-ray r2"></div><div class="pin-ring"></div><div class="pin-core"></div>
          <div class="pin-count" id="badge-budapest">0</div>
          <div class="pin-tooltip"><div class="pin-city">Budapest</div><div class="pin-meta" id="meta-budapest">0 photographs</div></div>
        </div>

        <div class="city-pin" id="pin-krakow" data-city="krakow" style="left:49.5%;top:31.8%">
          <div class="pin-ray"></div><div class="pin-ray r2"></div><div class="pin-ring"></div><div class="pin-core"></div>
          <div class="pin-count" id="badge-krakow">0</div>
          <div class="pin-tooltip"><div class="pin-city">Kraków</div><div class="pin-meta" id="meta-krakow">0 photographs</div></div>
        </div>

        <div class="city-pin" id="pin-istanbul" data-city="istanbul" style="left:71.5%;top:46%">
          <div class="pin-ray"></div><div class="pin-ray r2"></div><div class="pin-ring"></div><div class="pin-core"></div>
          <div class="pin-count" id="badge-istanbul">0</div>
          <div class="pin-tooltip"><div class="pin-city">Istanbul</div><div class="pin-meta" id="meta-istanbul">0 photographs</div></div>
        </div>

        <div class="city-pin" id="pin-turkiye" data-city="turkiye" style="left:80%;top:40%">
          <div class="pin-ray"></div><div class="pin-ray r2"></div><div class="pin-ring"></div><div class="pin-core"></div>
          <div class="pin-count" id="badge-turkiye">0</div>
          <div class="pin-tooltip"><div class="pin-city">Türkiye</div><div class="pin-meta" id="meta-turkiye">0 photographs</div></div>
        </div>
      </div>
    </div>

    <div class="selector-bar" id="city-bar">
      <button class="city-btn active" data-city="budapest">Budapest</button>
      <button class="city-btn" data-city="istanbul">Istanbul</button>
      <button class="city-btn" data-city="krakow">Kraków</button>
      <button class="city-btn" data-city="turkiye">Türkiye</button>
    </div>

    <div class="gallery-section">
      <div class="gallery-head">
        <div>
          <div class="gallery-city-name" id="gallery-city-name">Budapest, Hungary</div>
          <div class="gallery-city-line"><div class="gallery-city-rule"></div><div class="gallery-city-note" id="gallery-note">Selected city</div></div>
        </div>
        <div class="gallery-side">
          <div class="gallery-card">
            <div class="gallery-meta-top">
              <div>
                <div class="gallery-meta-kicker">Photographs in view</div>
                <div class="gallery-meta-count" id="gallery-meta">0 photographs</div>
              </div>
            </div>
            <div class="gallery-meta-copy" id="gallery-copy">Architectural stillness, layered light, and symmetry held just before motion.</div>
            <div class="gallery-progress"><div class="gallery-progress-bar" id="gallery-progress-bar"></div></div>
          </div>
        </div>
      </div>

      <div class="story-strip">
        <div class="feature-card" id="feature-card">
          <img id="feature-img" src="" alt="">
          <div class="feature-overlay">
            <div>
              <div class="feature-kicker">Featured frame</div>
              <div class="feature-title" id="feature-title"></div>
              <div class="feature-loc" id="feature-loc"></div>
            </div>
          </div>
        </div>
        <div class="city-insight">
          <div>
            <div class="city-insight-label">Atmosphere</div>
            <div class="city-insight-quote" id="insight-quote"></div>
            <div class="city-insight-copy" id="insight-copy"></div>
          </div>
          <div class="city-insight-meta">
            <div class="city-insight-item"><span class="k">Mood</span><span class="v" id="insight-mood"></span></div>
            <div class="city-insight-item"><span class="k">Focus</span><span class="v" id="insight-focus"></span></div>
          </div>
        </div>
      </div>

      <div class="gallery-grid" id="gallery-grid"></div>
    </div>
  </section>
</div>

<div class="footer-row">
  <div class="footer-card">
    <a href="https://www.instagram.com/fotozitake/" target="_blank" rel="noopener noreferrer" class="footer-link">@fotozitake on Instagram →</a>
    <span class="footer-total" id="ph-total"></span>
  </div>
</div>

<div id="lb">
  <button id="lb-close">Close ✕</button>
  <img id="lb-img" src="" alt="">
  <div id="lb-caption"></div>
</div>

<script>
const CITIES = {
  budapest: {
    label: 'Budapest, Hungary',
    short: 'Budapest',
    note: 'Danube light and sacred geometry',
    copy: 'Architectural stillness, layered light, and symmetry held just before motion.',
    quote: 'Stone, distance, and breath.',
    mood: 'Quiet grandeur',
    focus: 'Architecture',
    glow: { x: '53.5%', y: '38%' },
    featureIndex: 0,
    photos: [
      { src: '/photos/3.jpg', title: 'Convergence', loc: 'Budapest, Hungary 2026' },
      { src: '/photos/2.jpg', title: 'Exhale', loc: 'Budapest, Hungary 2026' },
      { src: '/photos/1.jpg', title: 'Sanctum', loc: 'Budapest, Hungary 2026' }
    ]
  },
  istanbul: {
    label: 'Istanbul, Türkiye',
    short: 'Istanbul',
    note: 'Water, memory, and thresholds',
    copy: 'A city that never fits inside a single description, only inside fragments of light.',
    quote: 'Every crossing is a sentence.',
    mood: 'Mythic motion',
    focus: 'Atmosphere',
    glow: { x: '71.5%', y: '46%' },
    featureIndex: 0,
    photos: [
      { src: '/photos/img20251227170642.jpg', title: 'Every Word Falls Short', loc: 'Istanbul, Türkiye 2025' },
      { src: '/photos/dramatic-ship.jpg', title: 'Gold', loc: 'Istanbul, Türkiye 2021' },
      { src: '/photos/12.jpg', title: 'Stone and Witness', loc: 'Istanbul, Türkiye 2021' },
      { src: '/photos/dsc_0563.jpg', title: 'Silence Above the City', loc: 'Istanbul, Türkiye 2022' },
      { src: '/photos/img20251227171746.jpg', title: 'Time, Ferried', loc: 'Istanbul, Türkiye 2025' }
    ]
  },
  krakow: {
    label: 'Kraków, Poland',
    short: 'Kraków',
    note: 'Street rhythm and afterglow',
    copy: 'Where old surfaces catch modern light and the street becomes the composition.',
    quote: 'The city hums in corners.',
    mood: 'Urban lyric',
    focus: 'Street geometry',
    glow: { x: '49.5%', y: '31.8%' },
    featureIndex: 0,
    photos: [
      { src: '/photos/topost.jpg', title: 'Echoes of Streets', loc: 'Kraków, Poland' },
      { src: '/photos/gem1-7.jpg', title: 'Street Symphony', loc: 'Kraków, Poland' }
    ]
  },
  turkiye: {
    label: 'Türkiye',
    short: 'Türkiye',
    note: 'Elsewhere in the country',
    copy: 'A broader frame for moments that belong to the country more than to one specific city.',
    quote: 'A wider breath of place.',
    mood: 'National texture',
    focus: 'Fragments',
    glow: { x: '80%', y: '40%' },
    featureIndex: 0,
    photos: [
      { src: '/photos/dsc_1275.jpg', title: 'Visual Poetry', loc: 'Türkiye' }
    ]
  }
};

let activeCity = 'budapest';

const totalPhotos = Object.values(CITIES).reduce((sum, city) => sum + city.photos.length, 0);
document.getElementById('hero-total-photos').textContent = totalPhotos;
document.getElementById('hero-total-cities').textContent = Object.keys(CITIES).length;
document.getElementById('ph-total').textContent = totalPhotos + ' photographs total';

function updateCounts() {
  Object.entries(CITIES).forEach(([key, city]) => {
    const count = city.photos.length;
    const badge = document.getElementById('badge-' + key);
    const meta = document.getElementById('meta-' + key);
    if (badge) badge.textContent = count;
    if (meta) meta.textContent = count + ' photograph' + (count !== 1 ? 's' : '');
  });
}

function escapeHtml(str='') {
  return str.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;');
}

function setGlow(city) {
  const glow = document.getElementById('map-glow');
  const data = CITIES[city];
  if (!glow || !data) return;
  glow.style.setProperty('--glow-x', data.glow.x);
  glow.style.setProperty('--glow-y', data.glow.y);
}

function setRouteHighlight(city) {
  document.querySelectorAll('.route-path').forEach(el => el.classList.remove('active'));
  if (city === 'krakow') document.getElementById('route-west')?.classList.add('active');
  if (city === 'budapest') document.getElementById('route-west')?.classList.add('active');
  if (city === 'istanbul') document.getElementById('route-east')?.classList.add('active');
  if (city === 'turkiye') document.getElementById('route-far-east')?.classList.add('active');
}

function renderGallery(city) {
  const data = CITIES[city];
  if (!data) return;
  activeCity = city;

  document.getElementById('gallery-city-name').textContent = data.label;
  document.getElementById('gallery-note').textContent = data.note;
  document.getElementById('gallery-meta').textContent = data.photos.length + ' photograph' + (data.photos.length !== 1 ? 's' : '');
  document.getElementById('gallery-copy').textContent = data.copy;
  document.getElementById('hero-city-short').textContent = data.short;
  document.getElementById('hero-city-copy').textContent = data.copy;
  document.getElementById('hero-featured-count').textContent = data.photos.length;
  document.getElementById('insight-quote').textContent = data.quote;
  document.getElementById('insight-copy').textContent = data.copy;
  document.getElementById('insight-mood').textContent = data.mood;
  document.getElementById('insight-focus').textContent = data.focus;

  const feature = data.photos[data.featureIndex] || data.photos[0];
  document.getElementById('feature-img').src = feature.src;
  document.getElementById('feature-img').alt = feature.title;
  document.getElementById('feature-title').textContent = feature.title;
  document.getElementById('feature-loc').textContent = feature.loc;
  document.getElementById('feature-card').onclick = () => openLb(feature.src, feature.title + ' — ' + feature.loc);

  const progress = document.getElementById('gallery-progress-bar');
  progress.style.width = Math.min((data.photos.length / totalPhotos) * 100, 100) + '%';

  const grid = document.getElementById('gallery-grid');
  grid.className = 'gallery-grid' + (data.photos.length <= 2 ? ' cols-2' : '');
  grid.style.opacity = '0';
  grid.style.transform = 'translateY(16px)';

  setTimeout(() => {
    grid.innerHTML = data.photos.map((p) =>
      `<div class="gallery-cell" data-src="${escapeHtml(p.src)}" data-title="${escapeHtml(p.title)}" data-loc="${escapeHtml(p.loc)}">
        <img src="${escapeHtml(p.src)}" alt="${escapeHtml(p.title)}" loading="lazy">
        <div class="gallery-cell-overlay">
          <div class="cell-title">${escapeHtml(p.title)}</div>
        </div>
      </div>`
    ).join('');

    grid.querySelectorAll('.gallery-cell').forEach(cell => {
      cell.addEventListener('click', () => openLb(cell.dataset.src, cell.dataset.title + ' — ' + cell.dataset.loc));
    });

    grid.style.opacity = '1';
    grid.style.transform = 'translateY(0)';
  }, 130);

  setGlow(city);
  setRouteHighlight(city);
}

function selectCity(city) {
  document.querySelectorAll('.city-pin').forEach(pin => pin.classList.toggle('active', pin.dataset.city === city));
  document.querySelectorAll('.city-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.city === city));
  renderGallery(city);
}

document.querySelectorAll('.city-pin').forEach(pin => pin.addEventListener('click', () => selectCity(pin.dataset.city)));
document.querySelectorAll('.city-btn').forEach(btn => btn.addEventListener('click', () => selectCity(btn.dataset.city)));

const lb = document.getElementById('lb');
const lbImg = document.getElementById('lb-img');
const lbCaption = document.getElementById('lb-caption');
function openLb(src, caption) {
  lbImg.src = src;
  lbCaption.textContent = caption || '';
  lb.style.display = 'flex';
  requestAnimationFrame(() => requestAnimationFrame(() => lb.classList.add('visible')));
}
function closeLb() {
  lb.classList.remove('visible');
  setTimeout(() => { lb.style.display = 'none'; lbImg.src = ''; }, 300);
}
document.getElementById('lb-close').addEventListener('click', closeLb);
lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });

const revealObs = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) entry.target.classList.add('visible');
  });
}, { threshold: .08 });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

updateCounts();
selectCity('budapest');
</script>
</body>
</html>
