<script>
const cur=document.getElementById('cur'),curR=document.getElementById('cur-r');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function anim(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(anim)})();
document.querySelectorAll('a,button,.r-item,.masonry-item,.thought-card,.pill').forEach(el=>{
  el.addEventListener('mouseenter',()=>{curR.style.width='50px';curR.style.height='50px';curR.style.borderColor='rgba(201,168,76,.65)'});
  el.addEventListener('mouseleave',()=>{curR.style.width='30px';curR.style.height='30px';curR.style.borderColor='rgba(201,168,76,.35)'});
});
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      [...e.target.querySelectorAll('.r-item,.stat,.thought-card,.masonry-item')].forEach((c,i)=>{
        c.style.transitionDelay=(i*.08)+'s';c.classList.add('reveal');
        setTimeout(()=>c.classList.add('visible'),i*80);
      });
    }
  });
},{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
document.querySelectorAll('.masonry-item').forEach(item=>{
  item.addEventListener('click',()=>{
    const img=item.querySelector('img');
    if(!img) return;
    document.getElementById('lb-img').src=img.src;
    document.getElementById('lb-meta').textContent=(item.dataset.title||'')+' · '+(item.dataset.loc||'');
    document.getElementById('lb').classList.add('open');
  });
});
document.getElementById('lb').addEventListener('click',e=>{
  if(e.target===e.currentTarget||e.target.id==='lb-close')
    document.getElementById('lb').classList.remove('open');
});
document.getElementById('lb-close').addEventListener('click',()=>document.getElementById('lb').classList.remove('open'));
function openPdf(url,title){
  if(!url){alert('PDF not attached yet.');return;}
  document.getElementById('pdf-title').textContent=title;
  document.getElementById('pdf-frame').src=url;
  document.getElementById('pdf-overlay').classList.add('open');
}
function closePdf(){
  document.getElementById('pdf-overlay').classList.remove('open');
  document.getElementById('pdf-frame').src='';
}
document.querySelectorAll('.r-body h3').forEach(h=>{
  h.addEventListener('click',()=>h.closest('.r-item').classList.toggle('open'));
});
document.querySelectorAll('.thought-card').forEach(card=>{
  card.addEventListener('click',()=>{
    document.getElementById('post-title').textContent=card.dataset.title||'';
    document.getElementById('post-date').textContent=card.dataset.date||'';
    document.getElementById('post-cat').textContent=card.dataset.cat||'';
    document.getElementById('post-body').innerHTML='<p>'+(card.dataset.excerpt||'')+'</p>';
    document.getElementById('post-overlay').classList.add('open');
    document.body.style.overflow='hidden';
  });
});
function closePost(){
  document.getElementById('post-overlay').classList.remove('open');
  document.body.style.overflow='';
}
window.closePost=closePost;
window.openPdf=openPdf;
window.closePdf=closePdf;
</script>
</body>
</html>
