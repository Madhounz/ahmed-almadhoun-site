<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Photography — Ahmed Almadhoun</title>
<meta name="description" content="Photography by Ahmed Almadhoun — cities, stillness, geometry, and atmosphere.">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#171411;
  --surface:#1f1b17;
  --surface2:#28231d;
  --surface3:#322b23;
  --border:#3b342c;
  --text:#f1ebe2;
  --muted:#a19589;
  --faint:#655b50;
  --accent:#c48a42;
  --accent-soft:rgba(196,138,66,.15);
  --accent-mid:#ad7336;
  --accent-light:#2a1a08;
  --shadow:0 30px 90px rgba(0,0,0,.35);
  --sans:'Inter',system-ui,sans-serif;
  --serif:'Fraunces',Georgia,serif;
}
html{scroll-behavior:smooth}
body{background:
  radial-gradient(circle at 20% 10%, rgba(196,138,66,.08), transparent 24%),
  radial-gradient(circle at 82% 18%, rgba(196,138,66,.05), transparent 22%),
  linear-gradient(180deg,#181410 0%, #171411 40%, #1a1612 100%);
  color:var(--text);font-family:var(--sans);overflow-x:hidden;min-height:100vh}
a{text-decoration:none}
button{font:inherit}

nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 28px;height:58px;display:flex;align-items:center;justify-content:space-between;background:rgba(23,20,17,.72);backdrop-filter:blur(20px);border-bottom:1px solid rgba(196,138,66,.08)}
.nav-name{font-family:var(--serif);font-size:16px;font-weight:300;color:var(--text);letter-spacing:-.01em;opacity:.84;transition:opacity .2s}
.nav-name:hover{opacity:1}
.nav-back{font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);opacity:.78;transition:opacity .2s}
.nav-back:hover{opacity:1}

.page-wrap{max-width:1280px;margin:0 auto;padding:0 32px}
.hero{padding:108px 0 26px;position:relative}
.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:40px;align-items:end}
.hero-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;opacity:.82}
.hero-title{font-family:var(--serif);font-size:clamp(48px,7vw,108px);font-weight:300;line-height:.92;letter-spacing:-.04em;color:var(--text);margin-bottom:18px}
.hero-sub{font-size:16px;line-height:1.8;color:var(--muted);max-width:520px}
.hero-side{justify-self:end;max-width:360px;width:100%}
.hero-card{position:relative;padding:22px 22px 18px;border:1px solid rgba(196,138,66,.1);background:linear-gradient(180deg,rgba(255,255,255,.02),rgba(255,255,255,.01));border-radius:18px;box-shadow:var(--shadow);overflow:hidden}
.hero-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at top right, rgba(196,138,66,.12), transparent 35%);pointer-events:none}
.hero-card-top{display:flex;justify-content:space-between;gap:16px;align-items:start;margin-bottom:26px}
.hero-card-label{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--faint);margin-bottom:8px}
.hero-card-value{font-family:var(--serif);font-size:34px;font-weight:300;line-height:1;color:var(--text)}
.hero-card-sub{font-size:12px;color:var(--muted);line-height:1.6;max-width:180px}
.hero-meter{height:1px;background:var(--border);position:relative;overflow:hidden}
.hero-meter::after{content:'';position:absolute;inset:0;width:62%;background:linear-gradient(90deg,var(--accent),transparent)}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:18px}
.hero-stat{padding-top:10px;border-top:1px solid rgba(255,255,255,.05)}
.hero-stat-num{font-family:var(--serif);font-size:24px;font-weight:300;color:var(--text)}
.hero-stat-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);margin-top:4px}

.stage-shell{position:relative;margin-top:20px;border:1px solid rgba(196,138,66,.08);border-radius:26px;background:linear-gradient(180deg,rgba(255,255,255,.02),rgba(255,255,255,.01));overflow:hidden;box-shadow:var(--shadow)}
.stage-shell::before{content:'';position:absolute;inset:0;background:
 radial-gradient(circle at 15% 15%, rgba(196,138,66,.08), transparent 26%),
 radial-gradient(circle at 88% 18%, rgba(196,138,66,.06), transparent 18%);
pointer-events:none}

.map-panel{position:relative;padding:22px 22px 0}
.map-top{display:flex;justify-content:space-between;align-items:end;gap:20px;margin-bottom:18px}
.map-title{font-family:var(--serif);font-size:clamp(24px,3vw,38px);font-weight:300;letter-spacing:-.02em;color:var(--text)}
.map-copy{font-size:13px;line-height:1.7;color:var(--muted);max-width:420px}
.map-canvas-wrap{position:relative;height:540px;border:1px solid var(--border);border-radius:18px;overflow:hidden;background:
 radial-gradient(circle at center, rgba(196,138,66,.03), transparent 42%),
 linear-gradient(180deg,#1a1612 0%, #171411 100%)}
#ph-map{width:100%;height:100%;display:block}
.map-glow{position:absolute;inset:0;background:radial-gradient(circle at var(--glow-x,56%) var(--glow-y,38%), rgba(196,138,66,.14), transparent 18%);pointer-events:none;opacity:0;transition:opacity .45s ease}
.map-canvas-wrap.city-focus .map-glow{opacity:1}
.city-orbit{position:absolute;inset:0;pointer-events:none}
.city-pin{position:absolute;transform:translate(-50%,-50%);cursor:pointer;z-index:4}
.pin-ring{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:38px;height:38px;border-radius:50%;border:1px solid rgba(196,138,66,.16);opacity:.45;transition:all .35s}
.pin-ray{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:74px;height:74px;border-radius:50%;border:1px solid rgba(196,138,66,.08);opacity:0;animation:ping 2.8s ease-out infinite}
.pin-ray.r2{animation-delay:1.4s}
.pin-core{position:relative;z-index:2;width:12px;height:12px;border-radius:50%;background:var(--accent);border:2px solid rgba(255,255,255,.18);box-shadow:0 0 0 0 rgba(196,138,66,.2);transition:transform .35s,background .35s,box-shadow .35s}
.pin-count{position:absolute;top:-10px;right:-11px;z-index:3;min-width:18px;height:18px;padding:0 5px;border-radius:999px;background:var(--accent);display:flex;align-items:center;justify-content:center;color:#171411;font-size:9px;font-weight:800;letter-spacing:.02em;transition:transform .3s}
.pin-tooltip{position:absolute;left:50%;bottom:calc(100% + 16px);transform:translateX(-50%) translateY(6px);padding:10px 13px;border:1px solid var(--border);border-radius:10px;background:rgba(33,28,23,.95);backdrop-filter:blur(16px);white-space:nowrap;opacity:0;pointer-events:none;transition:all .25s;box-shadow:0 18px 40px rgba(0,0,0,.28)}
.pin-tooltip::after{content:'';position:absolute;left:50%;top:100%;transform:translateX(-50%);border:6px solid transparent;border-top-color:rgba(33,28,23,.95)}
.pin-city{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text);margin-bottom:4px}
.pin-meta{font-size:11px;color:var(--muted)}
.city-pin:hover .pin-tooltip,.city-pin.active .pin-tooltip{opacity:1;transform:translateX(-50%) translateY(0)}
.city-pin:hover .pin-core,.city-pin.active .pin-core{transform:scale(1.55);background:#dea259;box-shadow:0 0 0 10px rgba(196,138,66,.08)}
.city-pin:hover .pin-count,.city-pin.active .pin-count{transform:scale(1.12)}
.city-pin.active .pin-ring{width:56px;height:56px;border-color:rgba(196,138,66,.28);opacity:1}
.city-pin.active .pin-ray{opacity:.55}

.route-svg{position:absolute;inset:0;pointer-events:none;z-index:2}
.route-path{fill:none;stroke:rgba(196,138,66,.18);stroke-width:1.2;stroke-dasharray:5 7;opacity:.55}
.route-path.active{stroke:rgba(196,138,66,.45);opacity:1;filter:drop-shadow(0 0 10px rgba(196,138,66,.2))}
.route-dot{fill:rgba(196,138,66,.32)}

.selector-bar{display:flex;flex-wrap:wrap;gap:8px;padding:16px 22px 22px}
.city-btn{padding:11px 15px;border-radius:999px;border:1px solid var(--border);background:var(--surface);color:var(--muted);font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;transition:all .22s}
.city-btn:hover{border-color:rgba(196,138,66,.3);color:var(--text);transform:translateY(-1px)}
.city-btn.active{background:var(--accent-light);color:var(--accent);border-color:rgba(196,138,66,.36);box-shadow:inset 0 0 0 1px rgba(196,138,66,.08)}

.gallery-section{padding:26px 22px 26px;border-top:1px solid rgba(255,255,255,.04)}
.gallery-head{display:grid;grid-template-columns:1.1fr .9fr;gap:28px;align-items:end;margin-bottom:24px}
.gallery-city-name{font-family:var(--serif);font-size:clamp(28px,4vw,58px);font-weight:300;letter-spacing:-.03em;color:var(--text);line-height:.98}
.gallery-city-line{display:flex;align-items:center;gap:12px;margin-top:10px}
.gallery-city-rule{width:34px;height:1px;background:rgba(196,138,66,.35)}
.gallery-city-note{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--accent)}
.gallery-side{justify-self:end;width:100%;max-width:360px}
.gallery-card{padding:16px 18px;border:1px solid var(--border);border-radius:16px;background:linear-gradient(180deg,rgba(255,255,255,.02),rgba(255,255,255,.01))}
.gallery-meta-top{display:flex;justify-content:space-between;gap:16px;align-items:end;margin-bottom:16px}
.gallery-meta-kicker{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--faint);margin-bottom:8px}
.gallery-meta-count{font-family:var(--serif);font-size:28px;font-weight:300;color:var(--text);line-height:1}
.gallery-meta-copy{font-size:12px;line-height:1.7;color:var(--muted)}
.gallery-progress{height:1px;background:var(--border);position:relative;overflow:hidden}
.gallery-progress-bar{position:absolute;top:0;left:0;height:100%;width:0;background:var(--accent);transition:width .35s ease}

.story-strip{display:grid;grid-template-columns:1.15fr .85fr;gap:18px;margin-bottom:18px}
.feature-card{position:relative;min-height:240px;border:1px solid var(--border);border-radius:18px;overflow:hidden;background:var(--surface2);cursor:pointer}
.feature-card img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(.94) brightness(.92);transition:transform .75s ease,filter .35s}
.feature-card:hover img{transform:scale(1.035);filter:saturate(1) brightness(1)}
.feature-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.82),rgba(0,0,0,.12) 45%,transparent 70%);display:flex;align-items:flex-end;padding:22px}
.feature-kicker{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:10px}
.feature-title{font-family:var(--serif);font-size:clamp(24px,3vw,38px);font-weight:300;line-height:1.02;color:#f4eee5;letter-spacing:-.03em;margin-bottom:8px;max-width:520px}
.feature-loc{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.68)}
.city-insight{padding:22px;border:1px solid var(--border);border-radius:18px;background:linear-gradient(180deg,rgba(255,255,255,.02),rgba(255,255,255,.01));display:flex;flex-direction:column;justify-content:space-between}
.city-insight-label{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:12px}
.city-insight-quote{font-family:var(--serif);font-size:clamp(22px,2.5vw,34px);font-weight:300;line-height:1.08;color:var(--text);letter-spacing:-.02em;margin-bottom:14px}
.city-insight-copy{font-size:13px;line-height:1.8;color:var(--muted)}
.city-insight-meta{display:flex;justify-content:space-between;gap:16px;margin-top:22px;padding-top:14px;border-top:1px solid rgba(255,255,255,.05)}
.city-insight-item span{display:block}
.city-insight-item .k{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);margin-bottom:4px}
.city-insight-item .v{font-size:13px;color:var(--text)}

.gallery-grid{columns:3;gap:8px;transition:opacity .45s ease, transform .45s ease}
.gallery-grid.cols-2{columns:2}
.gallery-cell{break-inside:avoid;margin-bottom:8px;position:relative;overflow:hidden;border-radius:10px;cursor:pointer;background:var(--surface2);border:1px solid rgba(255,255,255,.03)}
.gallery-cell img{width:100%;height:auto;display:block;transition:transform .7s ease,filter .35s ease;filter:saturate(.9) brightness(.93) contrast(1.04)}
.gallery-cell:hover img{transform:scale(1.04);filter:saturate(1) brightness(1)}
.gallery-cell-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.78),transparent 46%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:18px}
.gallery-cell:hover .gallery-cell-overlay{opacity:1}
.cell-title{font-family:var(--serif);font-size:18px;font-weight:300;color:#f3ede4;line-height:1.04;letter-spacing:-.02em;max-width:80%}

.footer-row{max-width:1280px;margin:0 auto;padding:0 32px 34px}
.footer-card{display:flex;justify-content:space-between;align-items:center;gap:20px;padding:20px 22px;border-top:1px solid var(--border)}
.footer-link{font-size:13px;font-weight:600;color:var(--accent)}
.footer-link:hover{text-decoration:underline}
.footer-total{font-size:11px;color:var(--faint);letter-spacing:.14em;text-transform:uppercase}

#lb{display:none;position:fixed;inset:0;background:rgba(4,3,2,.97);z-index:1000;align-items:center;justify-content:center;cursor:zoom-out;opacity:0;transition:opacity .3s}
#lb.open{display:flex}
#lb.visible{opacity:1}
#lb img{max-width:90vw;max-height:88vh;object-fit:contain}
#lb-close{position:absolute;top:24px;right:32px;background:none;border:none;color:rgba(255,255,255,.45);font-size:11px;letter-spacing:.16em;text-transform:uppercase;cursor:pointer;font-family:var(--sans);font-weight:600;transition:color .2s}
#lb-close:hover{color:rgba(255,255,255,.9)}
#lb-caption{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);font-family:var(--serif);font-size:16px;font-weight:300;color:rgba(255,255,255,.58);letter-spacing:.02em;text-align:center;padding:0 20px}

.reveal{opacity:0;transform:translateY(18px);transition:opacity .8s ease,transform .8s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
@keyframes ping{0%{transform:translate(-50%,-50%) scale(1);opacity:.55}100%{transform:translate(-50%,-50%) scale(2.8);opacity:0}}

@media(max-width:980px){
  .hero-grid,.gallery-head,.story-strip{grid-template-columns:1fr}
  .hero-side,.gallery-side{justify-self:start;max-width:none}
  .map-canvas-wrap{height:420px}
}
@media(max-width:768px){
  nav{padding:0 18px}
  .page-wrap{padding:0 18px}
  .hero{padding:92px 0 14px}
  .map-panel{padding:16px 16px 0}
  .selector-bar{padding:12px 16px 16px}
  .gallery-section{padding:20px 16px 20px}
  .gallery-grid{columns:2}
  .gallery-grid.cols-2{columns:1}
  .map-canvas-wrap{height:340px}
  .footer-row{padding:0 18px 24px}
  .footer-card{padding:18px 0;flex-direction:column;align-items:flex-start}
  .feature-card{min-height:220px}
}
</style>
</head>
