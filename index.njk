  function project(lat,lng,W,H){
    return{
      x:(lng-bounds.minLng)/(bounds.maxLng-bounds.minLng)*W,
      y:(1-(lat-bounds.minLat)/(bounds.maxLat-bounds.minLat))*H
    };
  }
  function fapColor(fap){
    if(fap<=0.001)return '#6aaa7a';
    if(fap<0.10)return '#c48a42';
    return '#e07060';
  }
  function draw(){
    const W=canvas.width,H=canvas.height;
    ctx.clearRect(0,0,W,H);
    const dark=document.body.classList.contains('dark-mode');
    ctx.fillStyle=dark?'#1a1d24':'#2b2926';
    ctx.fillRect(0,0,W,H);
    // Grid
    ctx.strokeStyle='rgba(255,255,255,0.04)';
    ctx.lineWidth=0.5;
    for(let i=0;i<=10;i++){ctx.beginPath();ctx.moveTo(W/10*i,0);ctx.lineTo(W/10*i,H);ctx.stroke();}
    for(let i=0;i<=6;i++){ctx.beginPath();ctx.moveTo(0,H/6*i);ctx.lineTo(W,H/6*i);ctx.stroke();}
    // Warsaw center
    const wp=project(wc.lat,wc.lng,W,H);
    ctx.beginPath();ctx.arc(wp.x,wp.y,6,0,Math.PI*2);
    ctx.fillStyle='rgba(196,138,66,0.25)';ctx.fill();
    ctx.strokeStyle='rgba(196,138,66,0.7)';ctx.lineWidth=1;ctx.stroke();
    ctx.font='500 11px Inter,sans-serif';ctx.fillStyle='rgba(196,138,66,0.8)';
    ctx.textAlign='center';ctx.fillText('Warsaw',wp.x,wp.y-10);
    // Connector lines
    corridors.forEach(c=>{
      const pt=project(c.lat,c.lng,W,H);
      const color=fapColor(c.fap);
      ctx.beginPath();ctx.moveTo(pt.x,pt.y);
      ctx.lineTo(pt.x+(wp.x-pt.x)*0.55,pt.y+(wp.y-pt.y)*0.55);
      ctx.strokeStyle=color+'66';ctx.lineWidth=1.5;
      ctx.setLineDash([4,5]);ctx.stroke();ctx.setLineDash([]);
    });
    // Dots
    corridors.forEach((c,i)=>{
      const pt=project(c.lat,c.lng,W,H);
      const color=fapColor(c.fap);
      const r=c._hovered?11:7;
      if(c._hovered){
        ctx.beginPath();ctx.arc(pt.x,pt.y,r+6,0,Math.PI*2);
        ctx.strokeStyle=color+'33';ctx.lineWidth=2;ctx.stroke();
      }
      ctx.beginPath();ctx.arc(pt.x,pt.y,r,0,Math.PI*2);
      ctx.fillStyle=color;ctx.fill();
      ctx.strokeStyle='rgba(0,0,0,0.35)';ctx.lineWidth=1.5;ctx.stroke();
      ctx.font=`600 ${r>7?11:9}px Inter,sans-serif`;
      ctx.fillStyle='#1a1714';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(i+1,pt.x,pt.y);
      if(c._hovered){
        ctx.font='500 11px Inter,sans-serif';
        ctx.fillStyle='rgba(240,235,226,0.92)';
        ctx.textBaseline='bottom';
        ctx.fillText(c.name.split('(')[0].trim(),pt.x,pt.y-r-6);
      }
    });
    ctx.textBaseline='alphabetic';
  }
  function resize(){
    canvas.width=canvas.parentElement.getBoundingClientRect().width;
    canvas.height=480;
    draw();
  }
  function getHit(mx,my){
    const W=canvas.width,H=canvas.height;
    for(let i=0;i<corridors.length;i++){
      const p=project(corridors[i].lat,corridors[i].lng,W,H);
      if((mx-p.x)**2+(my-p.y)**2<196)return i;
    }
    return -1;
  }
  canvas.addEventListener('mousemove',e=>{
    const r=canvas.getBoundingClientRect();
    const mx=e.clientX-r.left,my=e.clientY-r.top;
    const idx=getHit(mx,my);
    corridors.forEach((c,i)=>c._hovered=(i===idx));
    draw();
    if(idx>=0){
      const c=corridors[idx];
      document.getElementById('tt-name').textContent=c.name+' → '+c.dest;
      document.getElementById('tt-dist').textContent=c.dist+' km';
      document.getElementById('tt-time').textContent=c.time+' min';
      document.getElementById('tt-aes-raw').textContent=c.aesRaw+' km/h';
      document.getElementById('tt-aes-adj').textContent=c.aesAdj+' km/h';
      document.getElementById('tt-sf').textContent=c.sf.toFixed(2);
      document.getElementById('tt-cf').textContent=c.cf.toFixed(2);
      const fp=(c.fap*100).toFixed(1);
      const fel=document.getElementById('tt-fap');
      fel.textContent='FAP: '+fp+'% accessibility loss';
      fel.className='tt-fap '+(c.fap>0.10?'high':c.fap>0.001?'mid':'low');
      canvas.style.cursor='pointer';
      let tx=mx+16,ty=my-20;
      if(tx+250>canvas.width)tx=mx-260;
      if(ty<0)ty=10;
      tt.style.left=tx+'px';tt.style.top=ty+'px';
      tt.classList.add('visible');
    } else {
      tt.classList.remove('visible');
      canvas.style.cursor='default';
    }
  });
  canvas.addEventListener('mouseleave',()=>{
    corridors.forEach(c=>c._hovered=false);
    tt.classList.remove('visible');draw();
  });
  const themeBtn=document.getElementById('theme-btn');
  if(themeBtn)themeBtn.addEventListener('click',()=>setTimeout(draw,50));
  window.addEventListener('resize',resize);
  window.resizeMap=resize;
  resize();
})();
