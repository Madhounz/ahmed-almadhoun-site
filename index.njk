function toggleMap(){
  const m=document.getElementById('map-section');
  const btn=document.getElementById('map-toggle-btn');
  const icon=document.getElementById('map-btn-icon');
  const isOpen=m.style.maxHeight!=='0px'&&m.style.maxHeight!=='';
  if(isOpen){
    m.style.maxHeight='0';m.style.opacity='0';icon.textContent='↓';
  } else {
    m.style.maxHeight='900px';m.style.opacity='1';icon.textContent='↑';
    setTimeout(()=>{if(window.resizeMap)window.resizeMap();},50);
  }
}
window.toggleMap=toggleMap;
</script>
